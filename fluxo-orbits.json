    {
        "id": "775f1b17d3242307",
        "type": "function",
        "z": "fbabe5f201b3768a",
        "name": "function 4",
        "func": "//PEGAR CONTEXTO\nmsg.params = {\n    session_id: flow.get(\"session_id\"),\n    context: flow.get(\"context\") || {}\n};\n\n\nmsg.chatId = msg.payload.chatId;\nmsg.payload = msg.payload.content;\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 410,
        "y": 460,
        "wires": [
            [
                "30d73d8130212e2d",
                "91f814383b4bd4e9"
            ]
        ]
    },
    {
        "id": "1e040462e12e5110",
        "type": "function",
        "z": "fbabe5f201b3768a",
        "name": "function 5",
        "func": "//guardar contexto\nif(msg.payload.context){\n    flow.set(\"context\", msg.payload.context);\n}\n\nif(msg.payload.session_id){\n    flow.set(\"session_id\", msg.payload.session_id);\n}\n\nconst generic = msg.payload?.output?.generic || [];\nconst chatId = msg.chatId || msg.payload?.chatId;\n\nfor (const item of generic) {\n\n    // TEXTO\n    if (item.response_type === \"text\") {\n\n        node.send([{\n            payload: {\n                chatId,\n                type: \"message\",\n                content: item.text\n            }\n        }, null]);\n\n    }\n\n    // IMAGEM\n    else if (item.response_type === \"image\") {\n\n        node.send([{\n            payload: {\n                chatId,\n                type: \"photo\",\n                content: item.source,\n                caption: `${item.title || \"\"}\\n${item.description || \"\"}`\n            }\n        }, null]);\n\n    }\n\n    // OPÇÕES\n    else if (item.response_type === \"option\") {\n\n        const opts = {\n            reply_markup: JSON.stringify({\n                inline_keyboard: item.options.map(opt => [{\n                    text: opt.label,\n                    callback_data:\n                        opt.value?.input?.text ||\n                        opt.value?.text ||\n                        opt.label\n                }])\n            })\n        };\n\n        node.send([null, {\n            payload: {\n                chatId,\n                type: \"message\",\n                content: item.title || \"Escolha uma opção:\",\n                options: opts\n            }\n        }]);\n\n    }\n}\n\nreturn null;",
        "outputs": 2,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 790,
        "y": 520,
        "wires": [
