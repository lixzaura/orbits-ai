        "func": "//guardar contexto\nif(msg.payload.context){\n    flow.set(\"context\", msg.payload.context);\n}\n\nif(msg.payload.session_id){\n    flow.set(\"session_id\", msg.payload.session_id);\n}\n\nlet mens = msg.payload.output.generic[0]\nif (mens.response_type == \"text\"){\n    msg.payload = mens.text\n} else if (mens.response_type == \"image\"){\n    msg.payload = mens.title + \"\\n\" + mens.description;\n} else{\n    msg.payload = mens.title;\n}\nreturn msg;",
